{
  "name": "memory-management-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.mjs",
    "build": "npm run build:client",
    "build:client": "vite build",
    "preview": "vite preview",
    "build:cpp": "node server/scripts/build-cpp.mjs",
    "lint:quick": "node --check server/index.mjs && node --check vite.config.js"
  },
  "dependencies": {
    "chart.js": "^4.5.0",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.5"
  }
}
